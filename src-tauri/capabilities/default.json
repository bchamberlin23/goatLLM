{
  "identifier": "default",
  "description": "Default capabilities for MVP 2",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*:*" },
        { "url": "http://*:*" }
      ]
    },
    "shell:allow-open",
    {
      "identifier": "shell:default",
      "allow": [
        { "name": "git", "cmd": "git", "args": true },
        { "name": "open", "cmd": "open", "args": true }
      ]
    }
  ]
}
